{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["session_prefix", "mandatory_peers", "phase_gates"],
  "properties": {
    "manifest": { "type": "object" },
    "session_prefix": { "type": "string" },
    "mandatory_peers": { "type": "array", "items": { "type": "string" } },
    "phase_gates": {
      "type": "object",
      "properties": {
        "plan_required_before_arch_dispatch": { "type": "boolean" },
        "quality_gate_required_before_push": { "type": "boolean" }
      }
    }
  }
}
