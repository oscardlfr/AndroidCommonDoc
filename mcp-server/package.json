{
  "name": "androidcommondoc-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "androidcommondoc-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:sh": "bats ../scripts/tests/*.bats",
    "test:all": "vitest run && bats ../scripts/tests/*.bats",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/ tests/",
    "monitor": "node build/cli/monitor-sources.js",
    "generate-registry": "node --import tsx src/cli/generate-registry.ts",
    "sync-l0": "node --import tsx src/sync/sync-l0-cli.ts",
    "start": "node build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "yaml": "^2.8.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
